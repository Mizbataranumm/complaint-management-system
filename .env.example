# Server Configuration
PORT=3000

# MongoDB (optional - system works with JSON files by default)
MONGODB_URI=mongodb://localhost:27017/college_cms

# Gmail SMTP for Email Notifications
# Create an App Password: Google Account > Security > 2FA > App Passwords
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Session Secret (change this to a long random string in production)
SESSION_SECRET=college_cms_secret_key_2024

# College Info
COLLEGE_NAME=ABC Engineering College
COLLEGE_EMAIL=complaints@college.edu
